{
  "config": {
    "data": {
      "action_mix": {
        "platformer_biased": 0.15,
        "sticky": 0.35,
        "uniform": 0.5
      },
      "chunk_frames": 128,
      "episode_cap": 64,
      "platformer_probs": {
        "1": 0.1,
        "4": 0.2,
        "5": 0.05,
        "7": 0.35,
        "8": 0.25,
        "other": 0.05
      },
      "root": "data/procgen_coinrun_mini",
      "sticky_keep_prob": 0.85
    },
    "defaults": [
      "_self_"
    ],
    "demo": {
      "host": "127.0.0.1",
      "mock_if_missing": true,
      "port": 8000,
      "show_context_frames": 2,
      "split": "test"
    },
    "device": "auto",
    "env": {
      "center_agent": true,
      "channels": 3,
      "distribution_mode": "easy",
      "height": 64,
      "name": "coinrun",
      "num_actions": 15,
      "render_mode": "rgb_array",
      "splits": {
        "test": {
          "num_levels": 2,
          "start_level": 20000,
          "total_frames": 128
        },
        "train": {
          "num_levels": 4,
          "start_level": 0,
          "total_frames": 512
        },
        "val": {
          "num_levels": 2,
          "start_level": 10000,
          "total_frames": 128
        }
      },
      "use_backgrounds": true,
      "width": 64
    },
    "eval": {
      "batch_size": 2,
      "clips": 4,
      "context_ablations": [
        1,
        2
      ],
      "counterfactual_actions": [
        4,
        1,
        7,
        8
      ],
      "fvd_backend": "rgb_motion",
      "fvd_clip_len": 4,
      "probe_batch_size": 4,
      "probe_steps": 2,
      "rollout_steps": [
        1,
        2,
        4
      ],
      "split": "test"
    },
    "output_root": "runs",
    "project_name": "coinrun_world_model_mini",
    "reports": {
      "blog_dir": "outputs/blog",
      "metrics_glob": "runs/evaluate/*/metrics_summary.json",
      "report_dir": "outputs/report"
    },
    "seed": 123,
    "training": {
      "amp": false,
      "batch_size": 8,
      "epochs": 1,
      "log_every": 1,
      "lr": 0.0003,
      "max_steps": 2,
      "num_workers": 0,
      "save_every": 2,
      "val_every": 2,
      "weight_decay": 0.01
    },
    "transformer": {
      "checkpoint": null,
      "condition_actions": true,
      "context_frames": 2,
      "dropout": 0.1,
      "heads": 2,
      "latent_h": 8,
      "latent_w": 8,
      "layers": 2,
      "max_seq_len": 256,
      "temperature": 1.0,
      "top_k": 20,
      "train_horizon": 1,
      "width": 128
    },
    "vqvae": {
      "beta": 0.25,
      "checkpoint": null,
      "code_dim": 32,
      "codebook_size": 64,
      "hidden_channels": 64
    }
  },
  "splits": {
    "test": "data/procgen_coinrun_mini/test.zarr",
    "train": "data/procgen_coinrun_mini/train.zarr",
    "val": "data/procgen_coinrun_mini/val.zarr"
  }
}
